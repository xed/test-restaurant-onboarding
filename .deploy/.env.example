# Local Docker Compose defaults.
# Copy this file to `.deploy/.env` or export the variables in your shell before
# running `docker compose -f .deploy/docker-compose.local.yml up --build`.

# Backend
LOG_LEVEL=info
LLM_PROVIDER=openai
LLM_TIMEOUT=180s
READ_TIMEOUT=10s
WRITE_TIMEOUT=240s

# OpenAI provider. Required when LLM_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic provider. Required when LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
ANTHROPIC_BASE_URL=

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
